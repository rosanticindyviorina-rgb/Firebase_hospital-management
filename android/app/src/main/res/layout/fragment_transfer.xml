<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transfer Coins"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Send coins to a friend (10% platform fee)"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />

        <!-- Recipient ID Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Recipient"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />

        <EditText
            android:id="@+id/etRecipientId"
            style="@style/Widget.KamyabiCash.Input"
            android:layout_marginTop="@dimen/spacing_sm"
            android:hint="User ID or Referral Code"
            android:inputType="text"
            android:textSize="@dimen/text_md" />

        <!-- Amount Input -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Amount"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />

        <EditText
            android:id="@+id/etTransferAmount"
            style="@style/Widget.KamyabiCash.Input"
            android:layout_marginTop="@dimen/spacing_sm"
            android:hint="Minimum 3,000 coins"
            android:inputType="number"
            android:textSize="@dimen/text_xl"
            android:textAlignment="center" />

        <!-- Available Balance -->
        <TextView
            android:id="@+id/tvTransferBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textColor="@color/text_hint"
            android:textSize="@dimen/text_sm" />

        <!-- Fee Breakdown Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Fee Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fee (10%)"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvTransferFee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Coins"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:background="@color/divider" />

            <!-- Recipient Receives Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recipient receives"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:id="@+id/tvTransferReceive"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Coins"
                    android:textColor="@color/text_success"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSubmitTransfer"
            style="@style/Widget.KamyabiCash.Button.Primary"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="Send Coins" />

        <!-- Disclaimer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transfer Rules"
                android:textColor="@color/accent_gold"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="- Minimum transfer: 3,000 coins\n- A 10% platform fee is deducted from the transfer amount\n- Transfers are instant and cannot be reversed\n- You can transfer to any active user by their User ID or Referral Code\n- Both sender and recipient accounts must be in good standing"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_lg" />

    </LinearLayout>
</ScrollView>
