<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:orientation="vertical">

    <!-- Header Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt;"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_xl"
            android:paddingEnd="@dimen/spacing_md"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvTierTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Disclaimer -->
    <TextView
        android:id="@+id/tvTierDisclaimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_xs"
        android:lineSpacingExtra="2dp" />

    <!-- Cooldown Timer -->
    <TextView
        android:id="@+id/tvTierCooldown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_md"
        android:textColor="@color/accent_gold"
        android:textSize="@dimen/text_sm"
        android:visibility="gone" />

    <!-- Task List -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/taskContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md" />
    </ScrollView>
</LinearLayout>
