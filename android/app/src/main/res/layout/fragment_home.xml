<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back!"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <!-- Auto-Scrolling Banner Slider -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/bannerPager"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:overScrollMode="never" />

        <LinearLayout
            android:id="@+id/bannerIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/spacing_xs"
            android:orientation="horizontal" />

        <!-- ===== Balance Card ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_balance_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/balance_label"
                android:textColor="#B3FFFFFF"
                android:textSize="@dimen/text_sm" />

            <TextView
                android:id="@+id/tvBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:text="0 Coins"
                style="@style/Widget.KamyabiCash.Balance"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/tvBalancePkr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="= PKR 0"
                android:textColor="#80FFFFFF"
                android:textSize="@dimen/text_sm" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_earned_label"
                        android:textColor="#80FFFFFF"
                        android:textSize="@dimen/text_xs" />

                    <TextView
                        android:id="@+id/tvTotalEarned"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 Coins"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:orientation="horizontal"
                android:weightSum="3">

                <Button
                    android:id="@+id/btnWithdraw"
                    style="@style/Widget.KamyabiCash.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/withdraw_button"
                    android:textSize="@dimen/text_sm" />

                <Button
                    android:id="@+id/btnTransfer"
                    style="@style/Widget.KamyabiCash.Button.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="@string/transfer_coins"
                    android:textSize="@dimen/text_sm" />

                <Button
                    android:id="@+id/btnRedeemCode"
                    style="@style/Widget.KamyabiCash.Button.Outline"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/redeem_submit"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>
        </LinearLayout>

        <!-- Timers -->
        <TextView
            android:id="@+id/tvCycleTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm" />

        <TextView
            android:id="@+id/tvAdWatchCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_sm"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tvCooldownTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textColor="@color/accent_gold"
            android:textSize="@dimen/text_sm"
            android:visibility="gone" />

        <!-- ===== Earn Sections Title ===== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:text="@string/daily_tasks"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold" />

        <!-- Daily Loyalty Reward -->
        <LinearLayout
            android:id="@+id/loyaltyCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvLoyaltyTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/loyalty_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLoyaltyReward"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+20 Coins Today"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>

            <Button
                android:id="@+id/btnLoyaltyClaim"
                style="@style/Widget.KamyabiCash.Button.Primary"
                android:layout_width="100dp"
                android:layout_height="@dimen/button_height_sm"
                android:text="@string/task_claim"
                android:textSize="@dimen/text_sm" />
        </LinearLayout>

        <!-- ===== SILVER TIER CARD ===== -->
        <LinearLayout
            android:id="@+id/cardSilver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:background="@drawable/bg_tier_silver"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tier_silver_title"
                    android:textColor="@color/tier_silver"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_silver_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_silver_tasks"
                    android:textColor="@color/tier_silver"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tvSilverCooldown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_xs"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="@color/tier_silver"
                android:textSize="@dimen/text_xl" />
        </LinearLayout>

        <!-- ===== GOLD TIER CARD ===== -->
        <LinearLayout
            android:id="@+id/cardGold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_tier_gold"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tier_gold_title"
                    android:textColor="@color/tier_gold"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_gold_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_gold_tasks"
                    android:textColor="@color/tier_gold"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tvGoldCooldown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_xs"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="@color/tier_gold"
                android:textSize="@dimen/text_xl" />
        </LinearLayout>

        <!-- ===== DIAMOND TIER CARD ===== -->
        <LinearLayout
            android:id="@+id/cardDiamond"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_tier_diamond"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tier_diamond_title"
                    android:textColor="@color/tier_diamond"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_diamond_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_diamond_tasks"
                    android:textColor="@color/tier_diamond"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tvDiamondCooldown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_xs"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="@color/tier_diamond"
                android:textSize="@dimen/text_xl" />
        </LinearLayout>

        <!-- ===== ELITE TIER CARD ===== -->
        <LinearLayout
            android:id="@+id/cardElite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_tier_elite"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="@dimen/spacing_lg"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tier_elite_title"
                    android:textColor="@color/tier_elite"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_elite_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_sm" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/tier_elite_tasks"
                    android:textColor="@color/tier_elite"
                    android:textSize="@dimen/text_xs" />

                <TextView
                    android:id="@+id/tvEliteCooldown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/accent_gold"
                    android:textSize="@dimen/text_xs"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=">"
                android:textColor="@color/tier_elite"
                android:textSize="@dimen/text_xl" />
        </LinearLayout>

        <!-- Referral Code Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/your_referral_code"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_sm" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_sm">

                <TextView
                    android:id="@+id/tvReferralCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="KCXXXXXX"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_xl"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15" />

                <Button
                    android:id="@+id/btnShareCode"
                    style="@style/Widget.KamyabiCash.Button.Outline"
                    android:layout_width="100dp"
                    android:text="@string/share_code"
                    android:textSize="@dimen/text_sm" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/spacing_lg" />

    </LinearLayout>
</ScrollView>
