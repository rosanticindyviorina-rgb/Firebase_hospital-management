<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:scaleType="centerInside" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="Bank / Wallet Binding"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_lg"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Status Card -->
        <LinearLayout
            android:id="@+id/cardBoundStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Payment Details"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvBoundTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tvBoundAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:fontFamily="monospace" />

            <TextView
                android:id="@+id/tvBoundBank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body" />

            <TextView
                android:id="@+id/tvBoundMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/accent"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Locked — Contact support to change details"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_xs" />
        </LinearLayout>

        <!-- Binding Form -->
        <LinearLayout
            android:id="@+id/formBinding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bind Your Payment Account"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_md"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="You can only bind once. All withdrawals will go to this account."
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />

            <!-- Payment Method -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Payment Method"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />

            <Spinner
                android:id="@+id/spinnerMethod"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:padding="@dimen/spacing_sm" />

            <!-- Account Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Account Holder Name"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />

            <EditText
                android:id="@+id/etAccountTitle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="Full name as on account"
                android:inputType="textPersonName"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body" />

            <!-- Account Number -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Account / Wallet Number"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />

            <EditText
                android:id="@+id/etAccountNumber"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="03XXXXXXXXX or IBAN"
                android:inputType="phone"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body" />

            <!-- Bank Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="Bank / Wallet Name"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_xs" />

            <EditText
                android:id="@+id/etBankName"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_input"
                android:hint="e.g. EasyPaisa, JazzCash, HBL"
                android:inputType="text"
                android:paddingStart="@dimen/spacing_sm"
                android:paddingEnd="@dimen/spacing_sm"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body" />

            <Button
                android:id="@+id/btnSaveBinding"
                style="@style/Widget.KamyabiCash.Button.Primary"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="Bind Account" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
