    <!-- Tier Section Titles -->
    <string name="silver_section_title">SILVER SECTION</string>
    <string name="silver_disclaimer">Daily Limit: All tasks available once every 24 hours.\nTimer: 3-minute countdown per task.\nMultitasking: Switch to Gold, Diamond, or Elite while timer runs.\nReward credited after timer finishes and task is completed.</string>

    <string name="gold_section_title">GOLD SECTION</string>
    <string name="gold_disclaimer">Dual Sessions: Tasks refresh twice daily (8-hour interval).\n3-minute timer per task — complete other tiers while waiting.\nKC Coins added to wallet immediately after completion.\nMultiple clicking or spamming = Permanent Account Ban.</string>

    <string name="diamond_section_title">DIAMOND SECTION</string>
    <string name="diamond_disclaimer">Premium Access: Two sessions per 24 hours (8-hour gap).\n3-minute lockdown per task — switch to other tiers to earn more.\nBalance updated in real-time on completion.\nZero-tolerance for bot activity — violations = permanent blacklist.</string>

    <string name="elite_section_title">ELITE SECTION</string>
    <string name="elite_disclaimer">Exclusive: Tasks can be completed twice per day (8-hour gap).\n3-minute timer — explore Silver, Gold, or Diamond while waiting.\nKC Coins credited instantly on task completion.\nAvoid multiple clicking — system manipulation = Immediate Ban.</string>

    <!-- Withdrawal Disclaimer -->
    <string name="withdraw_disclaimer_title">Official Withdrawal Rules</string>
    <string name="withdraw_disclaimer">Minimum Exchange Rate: 2,000 KC Coins = 50 PKR.\nMinimum Withdrawal: 15,000 KC Coins required.\nTimeline: 24 to 72 business hours.\nProvide correct account details — Kamyabi Cash is NOT responsible for incorrect information.\nOne account policy — multiple accounts or VPNs = permanent ban.\nSuspicious activity = permanent ban and balance forfeiture.\nWithdrawals cannot be modified or cancelled once submitted.</string>

